# replace with your keys and data
# rename file to .env

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fastapi_db
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-here\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nyour-public-key-here\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_FROM_EMAIL=noreply@your-domain.com
APP_BASE_URL=http://localhost:8000
PASSWORD_RESET_EXPIRE_MINUTES=15
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:5173
# INVITE_URL is the URL embedded in invite emails (or printed to dev console).
# Leave commented to fall back to {APP_BASE_URL}/api/auth/accept-invite, a real backend endpoint.
# In a custom frontend with an /accept-invite route, set this to that URL instead.
# INVITE_URL=http://localhost:5173/accept-invite

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Where the OAuth callback redirects after issuing tokens. Defaults to first CORS_ORIGINS entry if unset.
OAUTH_FRONTEND_REDIRECT_URL=http://localhost:5173

# set to "production" in prod; any other value enables dev console output of email codes
ENVIRONMENT=development